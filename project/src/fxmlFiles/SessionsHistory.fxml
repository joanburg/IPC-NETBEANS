<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="500.0" prefWidth="700.0" spacing="15.0" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllerFiles.SessionHistoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Session History" />

        <TableView fx:id="sessionTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colDuration" prefWidth="100.0" text="Duration" />
                <TableColumn fx:id="colImported" prefWidth="100.0" text="Imported" />
                <TableColumn fx:id="colViewed" prefWidth="100.0" text="Visualized" />
                <TableColumn fx:id="colAnnotations" prefWidth="100.0" text="Anotations" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>

        <HBox spacing="30.0" style="-fx-background-color: #eeeeee; -fx-padding: 15; -fx-background-radius: 5;">
            <children>
                <VBox alignment="CENTER">
                    <Label style="-fx-font-weight: bold;" text="Total Imported" />
                    <Label fx:id="totalImportedLabel" text="0" />
                </VBox>
                <VBox alignment="CENTER">
                    <Label style="-fx-font-weight: bold;" text="Total Visualized" />
                    <Label fx:id="totalViewedLabel" text="0" />
                </VBox>
                <VBox alignment="CENTER">
                    <Label style="-fx-font-weight: bold;" text="Total Anotations" />
                    <Label fx:id="totalAnnotationsLabel" text="0" />
                </VBox>
            </children>
        </HBox>

        <HBox alignment="CENTER_RIGHT">
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" prefWidth="100.0" text="Go Back" />
            </children>
        </HBox>
    </children>
</VBox>
