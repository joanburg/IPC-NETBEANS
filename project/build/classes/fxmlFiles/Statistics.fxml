<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_CENTER" prefWidth="400.0" spacing="20.0" style="-fx-background-color: white;" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllerFiles.StatisticsController">
    <children>
        <Label fx:id="nameLabel" text="Activity Name" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <GridPane hgap="15.0" vgap="10.0">
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
                <ColumnConstraints halignment="LEFT" hgrow="SOMETIMES" minWidth="10.0" prefWidth="150.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            </rowConstraints>
            <children>
                <Label text="Total Distance:" GridPane.columnIndex="0" />
                <Label fx:id="distLabel" text="0.00 km" GridPane.columnIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Total Duration:" GridPane.rowIndex="1" />
                <Label fx:id="durLabel" text="00:00:00" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Average Speed:" GridPane.rowIndex="2" />
                <Label fx:id="speedLabel" text="0.0 km/h" GridPane.columnIndex="1" GridPane.rowIndex="2">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Average Pace:" GridPane.rowIndex="3" />
                <Label fx:id="paceLabel" text="0:00 min/km" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Elevation Gain (+):" GridPane.rowIndex="4" />
                <Label fx:id="posGainLabel" text="0 m" textFill="#27ae60" GridPane.columnIndex="1" GridPane.rowIndex="4">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Elevation Loss (-):" GridPane.rowIndex="5" />
                <Label fx:id="negGainLabel" text="0 m" textFill="#c0392b" GridPane.columnIndex="1" GridPane.rowIndex="5">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Min. Altitude:" GridPane.rowIndex="6" />
                <Label fx:id="minAltLabel" text="0 m" GridPane.columnIndex="1" GridPane.rowIndex="6">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>

                <Label text="Max. Altitude:" GridPane.rowIndex="7" />
                <Label fx:id="maxAltLabel" text="0 m" GridPane.columnIndex="1" GridPane.rowIndex="7">
                    <font><Font name="System Bold" size="13.0" /></font>
                </Label>
            </children>
        </GridPane>
    </children>
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
    </padding>
</VBox>
