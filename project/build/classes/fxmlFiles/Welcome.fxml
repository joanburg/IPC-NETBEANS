<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" stylesheets="@../styles/styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllerFiles.WelcomeController">
    <children>
        <Label text="Running la Safor">
            <font>
                <Font name="System Bold" size="36.0" />
            </font>
        </Label>
        <Label text="Track your activities, analyze your progress." textFill="#616161">
            <font>
                <Font size="14.0" />
            </font>
        </Label>
        <VBox alignment="CENTER" spacing="10.0">
            <children>
                <Button fx:id="loginBtn" minWidth="150.0" mnemonicParsing="false" onAction="#handleLoginNav" style="-fx-padding: 10 30; -fx-font-weight: bold; -fx-base: #2196F3; -fx-text-fill: white;" text="Log In">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </Button>
                <Button fx:id="registerBtn" minWidth="150.0" mnemonicParsing="false" onAction="#handleRegisterNav" style="-fx-padding: 10 20;" text="Register">
                    <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                    </padding>
                </Button>
            </children>
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
        </VBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
